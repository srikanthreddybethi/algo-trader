# ──────────────────────────────────────────────────
# AlgoTrader Environment Configuration
# Copy this to .env and fill in your values
# ──────────────────────────────────────────────────

# ─── AI API Keys (optional — enables AI-powered analysis) ───
# Set ONE of these to enable AI mode:
ANTHROPIC_API_KEY=
GEMINI_API_KEY=

# ─── Exchange API Keys (optional — for live trading) ───
# Paper trading works without any keys
BINANCE_API_KEY=
BINANCE_API_SECRET=
BYBIT_API_KEY=
BYBIT_API_SECRET=
KRAKEN_API_KEY=
KRAKEN_API_SECRET=
COINBASE_API_KEY=
COINBASE_API_SECRET=

# ─── Alpaca (Stocks + Crypto) ───
ALPACA_API_KEY=
ALPACA_API_SECRET=
ALPACA_PAPER=true

# ─── Database ───
DATABASE_URL=sqlite+aiosqlite:///./algotrader.db

# ─── Server ───
APP_ENV=development
# APP_ENV=production
